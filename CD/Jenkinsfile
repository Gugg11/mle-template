pipeline {
    agent any

    environment {
        DOCKERHUB_CREDS=credentials('mle-template')
        LC_ALL = "en_US.UTF-8"
        LANG    = "en_US.UTF-8"
        LANGUAGE = "en_US.UTF-8"
    }

options {
        timestamps()
        skipDefaultCheckout(true)
	}
    stages {
        stage('Checkout') {
            steps {
                checkout scm   // чтобы появились docker-compose.yml и functional_test.py
            }
        }

        stage('Login'){
            steps{
                bat 'docker login -u %DOCKERHUB_CREDS_USR% -p %DOCKERHUB_CREDS_PSW%'
                }
            }

        stage('Pull image'){
            steps{
                bat '''
                        docker pull gug1/mle-template:latest
                '''
            }
        }

       stage('Deploy with DB') {
            steps {
                // Останавливаем старые контейнеры, если остались
                bat 'docker-compose down || exit 0'
                // Генерируем .env с безопасными переменными (пароль из креденшелов)
                withCredentials([usernamePassword(
                    credentialsId: 'postgres-creds',
                    usernameVariable: 'POSTGRES_USER',
                    passwordVariable: 'POSTGRES_PASSWORD'
                )]) {
                    bat '''
                        echo POSTGRES_DB=mle_db > .env
                        echo POSTGRES_USER=%POSTGRES_USER% >> .env
                        echo POSTGRES_PASSWORD=%POSTGRES_PASSWORD% >> .env
                        echo POSTGRES_HOST=db >> .env
                        echo POSTGRES_PORT=5432 >> .env
                    '''
                }
                // Собираем и запускаем оба сервиса
                bat 'docker-compose build --no-cache'
                bat 'docker-compose up -d'
                // Ждём, пока БД станет доступна и API запустится
                bat 'timeout /t 25 /nobreak'
            }
        }

        stage('Functional test') {
            steps {
                // Используем Python-скрипт 
                bat 'docker exec mle-template python functional_test.py'
            }
        }
    }

    post {
        always {
            bat 'docker-compose down'
            bat 'docker logout'
            echo 'CD pipeline finished'
        }
    }
}
