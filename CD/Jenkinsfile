pipeline {
    agent any

    environment {
        DOCKERHUB_CREDS = credentials('mle-template')
    }

    options {
        timestamps()
    }

    stages {
        stage('Login') {
            steps {
                bat 'docker login -u %DOCKERHUB_CREDS_USR% -p %DOCKERHUB_CREDS_PSW%'
            }
        }

        stage('Pull image') {
            steps {
                bat 'docker pull gug1/mle-template:latest'
            }
        }

        stage('Remove old container') {
            steps {
                bat 'docker rm -f mle-template || exit 0'
            }
        }

        stage('Run container') {
            steps {
                bat 'for /f "tokens=*" %%i in (\'docker ps -q --filter "publish=8000"\') do docker rm -f %%i || exit 0'
                bat 'docker run --name mle-template -p 8000:8000 -d gug1/mle-template:latest'
            }
        }

        stage('Functional test') {
            steps {
                bat '''
                    timeout /t 10
                    docker exec mle-template python tests/functional/functional_test.py
                '''
            }
        }
    }

    post {
        always {
            bat '''
                docker rm -f mle-template || exit 0
                docker logout
            '''
            echo 'CD pipeline finished'
        }
    }
}
