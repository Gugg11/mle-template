pipeline {
    agent any

    environment {
        DOCKERHUB_CREDS = credentials('mle-template')
    }

    options {
        timestamps()
    }

    stages {
        stage('Login') {
            steps {
                bat 'docker login -u %DOCKERHUB_CREDS_USR% -p %DOCKERHUB_CREDS_PSW%'
            }
        }

        stage('Pull image') {
            steps {
                bat 'docker pull gug1/mle-template:latest'
            }
        }

        stage('Remove old container') {
            steps {
                bat 'docker rm -f mle-template || exit 0'
            }
        }

        stage('Run container') {
            steps {
                bat 'docker run --name mle-template -p 8000:8000 -d gug1/mle-template:latest'
            }
        }

        stage('Functional test') {
            steps {
                bat '''
                    timeout /t 10
                    curl -s -o response.json -w "%%{http_code}" -X POST http://localhost:8000/predict -H "Content-Type: application/json" -d "{\\"X\\":[[14.88,14.57,0.881,5.554,3.333,1.018,4.956]]}"
                    echo Response body:
                    type response.json
                    echo Container logs:
                    docker logs --tail 100 mle-template
                '''
            }
        }
    }

    post {
        always {
            bat '''
                docker rm -f mle-template || exit 0
                docker logout
            '''
            echo 'CD pipeline finished'
        }
    }
}
